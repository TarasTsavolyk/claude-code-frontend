# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Logs / deps (only relevant if you add tooling to this repo)
*.log
node_modules/

# Personal, machine-local Claude Code overrides — NOT shared.
# (The shared config lives in .claude/settings.json, which IS committed.)
.claude/settings.local.json

# Claude Code local worktree checkouts — scratch, never committed or copied into a project.
.claude/worktrees/

# Wizard detection cache — regenerated each session, holds machine-local absolute paths.
# (The .claude/.onboarded marker is NOT ignored: it IS committed so teammates aren't re-prompted.)
.claude/.wizard/

# IMPORTANT: do not ignore the .claude/ directory — it is the contents of this repo.
